# ================================================================
# 灵山胜境 AI 数字人导游系统 - 环境配置
# 复制此文件为 .env，按需修改后启动后端服务
# 本系统通过 vLLM 本地推理，无需任何云端 API Key！
# ================================================================

# ── vLLM 推理服务地址 ──────────────────────────────────────────
# 三个模型建议各自独立进程，分配不同端口

# 对话模型（Qwen3-VL-8B-Instruct）
# 启动命令：vllm serve Qwen/Qwen3-VL-8B-Instruct --port 8001 --dtype auto
VLLM_CHAT_BASE_URL=http://localhost:8001
QWEN_MODEL=Qwen/Qwen3-VL-8B-Instruct

# 视觉语言模型（Qwen3-VL-8B-Instruct）
# 启动命令：vllm serve Qwen/Qwen3-VL-8B-Instruct --port 8002 --dtype auto \
#               --limit-mm-per-prompt image=5 --max-model-len 8192
VLLM_VL_BASE_URL=http://localhost:8002
QWEN_VL_MODEL=Qwen/Qwen3-VL-8B-Instruct

# 嵌入模型（Qwen3-Embedding-0.6B，中文语义检索效果优秀）
# 启动命令：vllm serve Qwen/Qwen3-Embedding-0.6B --port 8003 --task embedding --dtype auto
VLLM_EMBED_BASE_URL=http://localhost:8003
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# ── 模型规格说明 ────────────────────────────────────────────────
# 显存充足（≥24GB）推荐 14B 版本：
#   QWEN_MODEL=Qwen/Qwen3-14B-Instruct
#   QWEN_VL_MODEL=Qwen/Qwen3-VL-8B-Instruct  （VL 暂无官方14B）
#
# 显存有限（8-12GB）推荐 7B 量化版本：
#   vllm serve Qwen/Qwen3-VL-8B-Instruct --port 8001 --dtype half --quantization awq
#
# 多 GPU 并行（--tensor-parallel-size）：
#   vllm serve Qwen/Qwen3-VL-8B-Instruct --port 8001 --tensor-parallel-size 2

# ── 数据库 ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./ai_guide.db
# PostgreSQL（生产推荐）：
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_guide

# ── 安全密钥 ───────────────────────────────────────────────────
SECRET_KEY=lingshan-change-this-in-production

# ── 存储目录 ───────────────────────────────────────────────────
KNOWLEDGE_BASE_DIR=./knowledge_base
CHROMA_DB_DIR=./chroma_db
UPLOAD_DIR=./uploads

# ── 语音合成 ───────────────────────────────────────────────────
TTS_PROVIDER=edge-tts

# ── 智能体参数 ─────────────────────────────────────────────────
MAX_HISTORY_TURNS=10
RAG_TOP_K=4
